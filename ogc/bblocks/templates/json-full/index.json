<%!
import json
from pathlib import Path
from ogc.bblocks.util import CustomJSONEncoder
%>
<%
MAX_INLINE_SNIPPET_SIZE = 100 * 1024  # 100 KiB

output = {**bblock.metadata}
if bblock.description:
    output['description'] = bblock.description
def _serialize_snippet(s):
    result = {k: v for k, v in s.items() if k not in ('full-code', 'code')}
    code = s.get('code')
    size_bytes = len(code) if isinstance(code, bytes) else len(code.encode('utf-8'))
    result['sizeBytes'] = size_bytes
    if isinstance(code, bytes):
        result['binary'] = True
    elif size_bytes <= MAX_INLINE_SNIPPET_SIZE:
        result['code'] = code
    # else: too large to inline - clients should fetch it via 'ref'/'url' instead
    return result

if bblock.examples:
    output['examples'] = [
        {**example, 'snippets': [_serialize_snippet(s) for s in example.get('snippets', [])]}
        if 'snippets' in example else example
        for example in bblock.examples
    ]
if bblock.example_prefixes:
    output['examplePrefixes'] = bblock.example_prefixes
if bblock.annotated_schema:
    output['annotatedSchema'] = bblock.annotated_schema_contents
if bblock.semantic_uplift:
    output['semanticUplift'] = bblock.semantic_uplift
if bblock.transforms:
    output['transforms'] = bblock.transforms
if git_repo:
    output['gitRepository'] = git_repo
    output['gitPath'] = git_path
%>
${json.dumps(output, indent=2, cls=CustomJSONEncoder)}